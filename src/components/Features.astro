---
import { en as t } from '../i18n/en';

const iconPaths: string[] = [
  '<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>',
  '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>',
  '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>',
  '<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>',
  '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
  '<polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/>',
];

const features = t.features.items.map((item, i) => ({
  ...item,
  icon: iconPaths[i] ?? '',
}));
---

<section
  id="features"
  class="py-24 scroll-mt-16"
  aria-labelledby="features-title"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <h2
      id="features-title"
      class="text-3xl sm:text-4xl font-bold text-center mb-16"
    >
      {t.features.title}
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((f) => (
        <div class="bg-graphite-deep rounded-[4px] border border-graphite p-6 hover:border-neon/30 transition-colors duration-200">
          <div
            class="w-10 h-10 rounded-[4px] bg-neon/10 flex items-center justify-center mb-4"
            aria-hidden="true"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#34d59a"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <Fragment set:html={f.icon} />
            </svg>
          </div>
          <h3 class="font-semibold text-white mb-2">{f.title}</h3>
          <p class="text-sm text-white/60 leading-relaxed">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
