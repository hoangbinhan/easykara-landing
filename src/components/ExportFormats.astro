---
import { en as t } from '../i18n/en';
---

<section class="py-16 border-y border-graphite" aria-labelledby="formats-title">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
    <h2
      id="formats-title"
      class="text-2xl sm:text-3xl font-bold mb-3"
    >
      {t.exportFormats.title}
    </h2>
    <p class="text-white/50 mb-10 text-sm">{t.exportFormats.subtitle}</p>

    <ul class="flex flex-wrap justify-center gap-3 list-none" role="list">
      {t.exportFormats.formats.map((fmt) => (
        <li>
          <span class="font-mono text-neon bg-neon/10 border border-neon/25 px-5 py-2 rounded-full text-sm inline-block">
            {fmt}
          </span>
        </li>
      ))}
    </ul>
  </div>
</section>
