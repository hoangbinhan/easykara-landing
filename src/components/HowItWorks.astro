---
import { en as t } from '../i18n/en';
---

<section
  id="how-it-works"
  class="py-24 bg-graphite-deep scroll-mt-16"
  aria-labelledby="hiw-title"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <h2
      id="hiw-title"
      class="text-3xl sm:text-4xl font-bold text-center mb-16"
    >
      {t.howItWorks.title}
    </h2>

    <ol class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 list-none">
      {t.howItWorks.steps.map((step, i) => (
        <li class="flex flex-col items-center text-center md:items-center">
          <div class="relative flex items-center justify-center mb-6">
            <div class="w-14 h-14 rounded-full bg-neon/10 border border-neon/30 flex items-center justify-center">
              <span class="font-mono text-neon text-base font-bold">{step.number}</span>
            </div>
            {i < t.howItWorks.steps.length - 1 && (
              <div
                class="hidden md:block absolute left-full top-1/2 -translate-y-1/2 w-full h-px bg-neon/15 ml-4"
                aria-hidden="true"
              />
            )}
          </div>
          <h3 class="font-semibold text-white text-lg mb-2">{step.title}</h3>
          <p class="text-sm text-white/60 leading-relaxed max-w-xs">
            {step.description}
          </p>
        </li>
      ))}
    </ol>
  </div>
</section>
